{
    "name": "omoikane-works/omoikane-simple-sales-reports",
    "description": "Generates simple sales reports for Welcart.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Omoikane Works",
            "homepage": "https://github.com/omoikane-works"
        },
        {
            "name": "Kiminori KATO",
            "email": "kimikato@morgenrot.in"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "mustache/mustache": "^3.2"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.11",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "OmoikaneWorks\\SimpleSalesReports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmoikaneWorks\\SimpleSalesReports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "find omoikane-simple-sales-reports.php src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
        "phpcs": "phpcs -s omoikane-simple-sales-reports.php src tests",
        "phpcbf": "phpcbf omoikane-simple-sales-reports.php src tests",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "make-pot": "wp i18n make-pot . languages/omoikane-simple-sales-reports.pot --exclude=node_modules,vendor,tests,build",
        "test": "phpunit -c phpunit.xml.dist",
        "phpunit": "phpunit -c phpunit.xml.dist",
        "coverage": "XDEBUG_MODE=coverage composer phpunit -- --coverage-text",
        "coverage-html": "XDEBUG_MODE=coverage phpunit -c phpunit.xml.dist --coverage-html build/coverage",
        "build": "bash bin/build-zip.sh"
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.2.31"
        },
        "sort-packages": true
    },
    "extra": {
        "phpcodesniffer-composer-installer": {
            "includes": [
                "wp-coding-standards/wpcs",
                "phpcompatibility/php-compatibility",
                "phpcompatibility/phpcompatibility-wp"
            ]
        }
    }
}
